# Copy to secrets.toml (gitignored) and fill in from the service-account
# key JSON minted after `terraform apply` (see terraform/outputs.tf for the
# service account email, README.md Step 3 for the `gcloud iam
# service-accounts keys create` command).
[destination.bigquery.credentials]
project_id = "olist-geo-<suffix>"
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "olist-pipeline@olist-geo-<suffix>.iam.gserviceaccount.com"
